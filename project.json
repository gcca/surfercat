  "version": "0.1.0",
  "sources": [ "src/**", "c/yyjson.c3" ],
  "test-sources": [ "test/**" ],
  "cc": "clang++",
  "cflags": "-std=c++23 -mmacosx-version-min=11.0",
  "macos-min-version": "11.0",
  "c-include-dirs": [ "c" ],
  "link-args": [
    "-std=c++23",
    "-Ic",
    "-xc++",
