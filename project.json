    "c/yyjsonshim.cpp",
    "c/session.pb.cc",
    "c/session.grpc.pb.cc",
    "c/sessionshim.cpp",
    "-I/opt/homebrew/Cellar/grpc/1.82.1/include",
    "-I/opt/homebrew/Cellar/abseil/20260107.1/include",
    "-I/opt/homebrew/Cellar/c-ares/1.34.8/include",
    "-I/opt/homebrew/Cellar/openssl@3/3.6.3/include",
    "-pthread",
